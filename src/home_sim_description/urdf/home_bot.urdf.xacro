<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="home_bot">
  <material name="blue">
    <color rgba="0.1 0.35 0.8 1"/>
  </material>
  <material name="black">
    <color rgba="0.02 0.02 0.02 1"/>
  </material>
  <material name="red">
    <color rgba="0.9 0.05 0.02 1"/>
  </material>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.14"/>
      <geometry>
        <box size="0.42 0.32 0.16"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.14"/>
      <geometry>
        <box size="0.42 0.32 0.16"/>
      </geometry>
    </collision>
    <visual>
      <origin xyz="0.245 0 0.175"/>
      <geometry>
        <box size="0.07 0.20 0.07"/>
      </geometry>
      <material name="red"/>
    </visual>
  </link>

  <link name="left_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.570796 0 0"/>
      <geometry>
        <cylinder radius="0.075" length="0.045"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>

  <link name="right_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.570796 0 0"/>
      <geometry>
        <cylinder radius="0.075" length="0.045"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>

  <link name="caster">
    <visual>
      <geometry>
        <sphere radius="0.04"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>

  <link name="imu_link"/>

  <link name="camera_link">
    <visual>
      <geometry>
        <box size="0.08 0.16 0.06"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>

  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin xyz="0 0.19 0.08" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="0 -0.19 0.08" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster"/>
    <origin xyz="-0.16 0 0.04"/>
  </joint>

  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0.24"/>
  </joint>

  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="0.24 0 0.34"/>
  </joint>
</robot>
