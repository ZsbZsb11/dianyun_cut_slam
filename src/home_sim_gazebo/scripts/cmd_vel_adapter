#!/usr/bin/env python3
import rclpy
from geometry_msgs.msg import Twist
from rclpy.node import Node


class CmdVelAdapter(Node):
    def __init__(self):
        super().__init__('cmd_vel_adapter')
        self.declare_parameter('invert_linear_x', True)
        self.declare_parameter('invert_angular_z', True)
        self.invert_linear_x = self.get_parameter('invert_linear_x').value
        self.invert_angular_z = self.get_parameter('invert_angular_z').value
        self.publisher = self.create_publisher(Twist, '/cmd_vel_gz', 10)
        self.subscription = self.create_subscription(
            Twist,
            '/cmd_vel',
            self.on_cmd_vel,
            10,
        )

    def on_cmd_vel(self, msg):
        self.invert_linear_x = self.get_parameter('invert_linear_x').value
        self.invert_angular_z = self.get_parameter('invert_angular_z').value

        adapted = Twist()
        adapted.linear.x = -msg.linear.x if self.invert_linear_x else msg.linear.x
        adapted.linear.y = msg.linear.y
        adapted.linear.z = msg.linear.z
        adapted.angular.x = msg.angular.x
        adapted.angular.y = msg.angular.y
        adapted.angular.z = -msg.angular.z if self.invert_angular_z else msg.angular.z
        self.publisher.publish(adapted)


def main():
    rclpy.init()
    node = CmdVelAdapter()
    try:
        rclpy.spin(node)
    except KeyboardInterrupt:
        pass
    finally:
        node.destroy_node()
        if rclpy.ok():
            rclpy.shutdown()


if __name__ == '__main__':
    main()
